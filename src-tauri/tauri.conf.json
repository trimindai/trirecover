{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TriRecover",
  "version": "0.3.0",
  "identifier": "tech.trimind.trirecover",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TriRecover",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Read-only file recovery for Windows.",
    "longDescription": "TriRecover is a read-only data recovery tool. It scans disk images for known file signatures (JPEG, PNG, PDF, MP4, ZIP, OOXML, and more) and recovers them to a directory you choose. The source drive is never written to.",
    "publisher": "TriMind AI",
    "homepage": "https://trirecover.trimind.tech",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  }
}
