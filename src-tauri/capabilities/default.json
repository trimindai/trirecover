{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities granted to the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-read-file",
    "shell:allow-open"
  ]
}
